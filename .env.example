# セッション署名用の秘密鍵（本番環境では必ず設定し、推測困難な長いランダム文字列にすること）
# 未設定時は開発用の既定値が使われます。本番では設定必須。
# 例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))" で生成
# set SESSION_SECRET=your_long_random_string (Windows)
# export SESSION_SECRET=your_long_random_string (Linux/Mac)
SESSION_SECRET=

# 本番サーバーでは production にすると Cookie が HTTPS 時のみ送信されます
# set NODE_ENV=production (Windows)
# export NODE_ENV=production (Linux/Mac)
# NODE_ENV=

# メール送信用パスワード（SMTP認証用）
# 本番環境では必須です。settings.json には保存しない運用にしてください。
# 開発環境では未設定時に管理画面設定の値を利用できます。
# set MAIL_PASSWORD=your_password (Windows)
# export MAIL_PASSWORD=your_password (Linux/Mac)
MAIL_PASSWORD=

# フロント/APIを別オリジンに分ける場合のみ設定（カンマ区切り）
# 例: ALLOWED_ORIGINS=http://localhost:5173,https://app.example.com
# 未設定時は同一オリジン運用（現状どおり）
ALLOWED_ORIGINS=

# リバースプロキシ配下で動かす場合は 1 または true
# Cookieのsecure判定や req.ip をプロキシ経由で正しく扱うために使用
TRUST_PROXY=

# 性能監視: 1秒以上かかったリクエストをログ出力（本番デバッグ用）
# ENABLE_PERF_LOG=true
# PERF_LOG_THRESHOLD_MS=1000

# --- 販売管理（sales-mgmt）との連携 API（/api/integration/*）---
# 未設定のとき連携ルートは 503。販管側 .env の ERP_SYNC_API_KEY と必ず同じ値にする。
# 例: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ERP_SYNC_API_KEY=

# 空の商品・顧客マスタを試す場合（開発のみ）: npm run seed:erp-dev
