{
  "name": "web-order",
  "version": "1.0.0",
  "description": "",
  "main": "products.js",
  "scripts": {
    "test": "npm run test:all",
    "test:s": "jest tests/s-rank --runInBand",
    "test:a": "jest tests/a-rank --runInBand",
    "test:b": "jest tests/b-rank --runInBand",
    "test:risk": "jest tests/risk-driven --runInBand",
    "test:api": "jest tests/s-rank tests/a-rank tests/b-rank tests/risk-driven --runInBand --coverage",
    "coverage:baseline": "jest tests/s-rank tests/a-rank tests/b-rank tests/risk-driven --runInBand --coverage --coverageReporters=text-summary --coverageReporters=lcov --coverageReporters=json-summary",
    "coverage:baseline:save": "node scripts/save-coverage-baseline.js",
    "coverage:gap-report": "node scripts/coverage-gap-report.js",
    "test:e2e": "playwright test",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "node scripts/run-test-all.js",
    "start": "node server.js",
    "dev": "nodemon --legacy-watch server.js",
    "test:flake": "node scripts/run-flake-check.js",
    "test:load": "node scripts/load-test.js"
  },
  "nodemonConfig": {
    "watch": ["server.js", "routes", "services", "utils", "middlewares", "validators", "dbPaths.js"],
    "ext": "js",
    "delay": "800",
    "ignore": [
      "*.json",
      "sessions/*",
      "node_modules",
      "coverage",
      "tests"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "csv-parse": "^6.1.0",
    "dotenv": "^16.4.5",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-fileupload": "^1.5.2",
    "express-session": "^1.18.2",
    "helmet": "^7.1.0",
    "iconv-lite": "^0.7.2",
    "multer": "^2.0.2",
    "node-cron": "^3.0.3",
    "nodemailer": "^7.0.11",
    "session-file-store": "^1.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "autocannon": "^8.0.0",
    "jest": "^30.2.0",
    "nodemon": "^3.1.11",
    "supertest": "^7.1.4"
  }
}
